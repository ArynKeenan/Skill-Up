{
    "manifest_version": 3,
    "version": "1.0",
    "name": "Skill Up",
    "action": {
        "default_popup": "index.html",
        "default_icon": "skillUpLogo.png"
    },
    "permissions": ["activeTab", "storage", "scripting"],
    "content_scripts": [
        {
        "matches": ["<all_urls>"],
        "js": ["index.js"]
        }
    ]
}